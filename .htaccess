<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect root to home.html
    RewriteRule ^$ home.html [L]

    # Redirect /professores to professors/corpo_docente.html
    RewriteRule ^professores/?$ professores/corpo_docente.html [L,R=301]

    # Clean URLs: Allow access without .html extension
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.html -f
    RewriteRule ^(.*)$ $1.html [NC,L]

    # Ensure mp4 files are served with correct MIME type
    AddType video/mp4 .mp4
</IfModule>
